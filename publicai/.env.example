# Local secrets — copy to config.local.js (gitignored)
OPENAI_API_KEY=sk-your-openai-api-key

# Stripe Test Mode (not used in Sprint 27)
STRIPE_MODE=mock
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Supabase (Sprint 27 — Database Migration V1)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SEED_SECRET=your-random-seed-secret

# Optional: force auth provider on Vercel build (defaults to supabase when keys present)
AUTH_PROVIDER=supabase
