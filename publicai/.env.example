# Provider API keys (production)
OPENAI_API_KEY=sk-your-openai-api-key
GOOGLE_API_KEY=your-gemini-api-key
# ANTHROPIC_API_KEY=          # Claude — not yet live
# DEEPSEEK_API_KEY=           # DeepSeek — waiting balance/API key
# QWEN_API_KEY=               # Qwen — waiting API key

# Email (transactional only — mass sending disabled)
EMAIL_PROVIDER=mock
# mock | smtp | resend | postmark
EMAIL_DISABLE_SEND=false
# Set EMAIL_DISABLE_SEND=true in development to force mock logging only

# IONOS SMTP placeholder (production transactional email)
SMTP_HOST=smtp.ionos.com
SMTP_PORT=587
SMTP_USER=your-mailbox@your-domain.com
SMTP_PASS=your-ionos-mailbox-password
SMTP_FROM=hello@zwima-group.info
SMTP_SECURE=false

# Stripe Test Mode (not used in Sprint 27)
STRIPE_MODE=mock
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Supabase (Sprint 27 — Database Migration V1)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SEED_SECRET=your-random-seed-secret

# Migrations (Vercel serverless): session pooler on port 5432 — NOT the direct db.* host
# Supabase Dashboard → Project Settings → Database → Connection string → Session pooler (URI)
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres
# Runtime / app queries: transaction pooler on port 6543 (optional)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres
# Plain database password (recommended for migrations on Vercel — avoids URL encoding issues)
SUPABASE_DB_PASSWORD=your-database-password
# Or Supabase personal access token (Dashboard → Account → Access Tokens)
SUPABASE_ACCESS_TOKEN=sbp_your_access_token
