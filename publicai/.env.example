# Local secrets — copy to config.local.js (gitignored)
OPENAI_API_KEY=sk-your-openai-api-key

# Stripe Test Mode (not used in Sprint 27)
STRIPE_MODE=mock
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Supabase (Sprint 27 — Database Migration V1)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SEED_SECRET=your-random-seed-secret

# Optional: direct Postgres connection for automatic migrations on Vercel
# Copy from Supabase Dashboard → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
SUPABASE_DB_PASSWORD=your-database-password
# Or Supabase personal access token (Dashboard → Account → Access Tokens)
SUPABASE_ACCESS_TOKEN=sbp_your_access_token
