# Email — app-owned transactional mail (Supabase Auth email disabled)
# Local/test/preview: mock allowed
# Production with EMAIL_PROVIDER=smtp: real SMTP required unless COMMERCIAL_BETA_MODE=true

EMAIL_PROVIDER=smtp
EMAIL_DISABLE_SEND=false
COMMERCIAL_BETA_MODE=true

# IONOS SMTP (founder supplies in Vercel — do not commit secrets)
SMTP_HOST=smtp.ionos.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=info@zwima-group.com
SMTP_SECURE=false

# Stripe — keep mock/test until founder supplies keys
# STRIPE_MODE: mock | test | live
STRIPE_MODE=mock
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Provider API keys (production)
OPENAI_API_KEY=
GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
# QWEN_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
