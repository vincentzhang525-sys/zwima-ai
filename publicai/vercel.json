{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/db/migrate.js": {
      "includeFiles": "supabase/**",
      "maxDuration": 60
    },
    "api/changelog/index.js": {
      "includeFiles": "CHANGELOG.md"
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "status": 404, "dest": "/404.html" }
  ]
}
