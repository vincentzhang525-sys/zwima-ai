{
  "name": "zwima-gateway",
  "version": "0.1.0",
  "description": "Zwima Gateway MVP V0.1 – OpenAI API proxy with credits",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "db:migrate": "node src/db/migrate.js",
    "db:seed": "node src/db/seed.js",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "test:smoke": "node scripts/smoke-test.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^8.0.4",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1"
  },
  "optionalDependencies": {
    "ioredis": "^5.4.2"
  }
}
